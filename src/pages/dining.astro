---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

// Asset prefix — respects Astro `base` for GitHub Pages deploys.
const A = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/assets`;

// Dining page images
const imgDiningHero = `${A}/imgDiningHero.png`;
const imgGalleryTables = `${A}/imgGalleryTables.png`;
const imgGalleryBuffets = `${A}/imgGalleryBuffets.png`;
const imgGalleryBenches = `${A}/imgGalleryBenches.png`;
const imgGalleryChairs = `${A}/imgGalleryChairs.png`;
const imgDiningCastello = `${A}/imgDiningCastello.png`;
const imgDiningMadera = `${A}/imgDiningMadera.png`;
const imgDiningVilla = `${A}/imgDiningVilla.png`;
const imgDiningCamden = `${A}/imgDiningCamden.png`;
const imgDiningMaderaRound = `${A}/imgDiningMaderaRound.png`;
const imgDiningFarmhouse = `${A}/imgDiningFarmhouse.png`;
const imgDiningKolt = `${A}/imgDiningKolt.png`;
const imgDiningHudson = `${A}/imgDiningHudson.png`;
const imgDiningMadera2 = `${A}/imgDiningMadera2.png`;
const imgSaleOsaka = `${A}/imgSaleOsaka.png`;
const imgSaleBarnDoors = `${A}/imgSaleBarnDoors.png`;
const imgSaleDining = `${A}/imgSaleDining.png`;
const imgSaleCountdownBg = `${A}/imgSaleCountdownBg.png`;
const imgBundleOsakaTable = `${A}/imgBundleOsakaTable.png`;
const imgBundleOsakaChairs = `${A}/imgBundleOsakaChairs.png`;
const imgBundleOsakaBuffet = `${A}/imgBundleOsakaBuffet.png`;
// Reuse from landing page
const imgFrame15 = `${A}/imgFrame15.png`;
const imgFrame20 = `${A}/imgFrame20.png`;
const imgFrame13 = `${A}/imgFrame13.png`;
const imgFrame18 = `${A}/imgFrame18.png`;
const imgHereToHelp = `${A}/imgHereToHelp.png`;
const imgProcessBg = `${A}/imgProcessBg.png`;
const imgHeartPlus = `${A}/imgHeartPlus.svg`;
const imgBaggageClaim = `${A}/imgBaggageClaim.svg`;
const imgEllipse2 = `${A}/imgEllipse2.svg`;
const imgImage10 = `${A}/imgImage10.png`;
const imgImage12 = `${A}/imgImage12.png`;
const imgImage13 = `${A}/imgImage13.png`;
const imgFrame63 = `${A}/imgFrame63.png`;

const products = [
  { img: imgDiningCastello, title: 'Castello Dining Table', price: 'from $1,785', desc: 'Natural Reclaimed Teak', badge: 'New' },
  { img: imgDiningMadera, title: 'Madera Dining Table', price: 'from $1,870', desc: 'Natural Reclaimed Teak' },
  { img: imgDiningVilla, title: 'Villa Dining Table', price: 'from $1,235', desc: 'Natural Reclaimed Teak' },
  { img: imgDiningCamden, title: 'Camden Dining Table', price: 'from $1,425', desc: 'Natural Reclaimed Teak' },
  { img: imgDiningMaderaRound, title: 'Madera Round Table', price: 'from $1,865', desc: 'Natural Reclaimed Teak' },
  { img: imgDiningFarmhouse, title: 'Farmhouse Dining Table', price: 'from $1,599', desc: 'Natural Reclaimed Teak', badge: 'New' },
  { img: imgDiningKolt, title: 'Kolt Dining Table', price: '$1,445', desc: 'Natural Reclaimed Teak + Black Metal', badge: "Designer's Pick", dot: true },
  { img: imgDiningHudson, title: 'Hudson Dining Table', price: 'from $1,855', desc: 'Natural Reclaimed Teak + Black Metal' },
  { img: imgDiningMadera2, title: 'Madera Dining Table', price: 'from $1,025', desc: 'Natural Reclaimed Teak' },
];

const saleCards = [
  { img: imgSaleOsaka, title: 'Osaka Dining Table', desc: 'Natural Reclaimed Teak + Grey Concrete', discount: '-25%' },
  { img: imgSaleBarnDoors, title: 'Grand X Barn Doors', desc: 'Now $885 was $1,075', discount: '-18%' },
  { img: imgSaleDining, title: 'Atelier Dining Table', desc: 'Save up to $1000', discount: '-30%' },
];

const collections = [
  { name: 'Madera', img: imgFrame15 },
  { name: 'Osaka', img: imgFrame20 },
  { name: 'Hudson', img: imgFrame13 },
  { name: 'Camden', img: imgFrame18, badge: 'Popular' },
  { name: 'Hudson', img: imgFrame13 },
];

const reviewers = [
  { name: 'Paul G.', quote: '"This is an example review of how much they loved the product and how great it was"', offset: '' },
  { name: 'Daniel Jackson', quote: '"Solid wood, no wobble. Even better than the photos. Obsessed."', offset: 'pt-[168px]' },
  { name: 'Paul G.', quote: '"Took weeks to ship but honestly worth every single day."', offset: '' },
  { name: 'Stephanie Lewis', quote: '"Bought one, came back for two more. Quality speaks itself."', offset: 'pt-[168px]' },
  { name: 'Jason Murphy', quote: '"Heavier than expected in the best way. Feels built to last."', offset: 'pt-[88px]' },
  { name: 'Paul G.', quote: '"Assembly was simple, looks way more expensive than it cost."', offset: '' },
];

const marqueeItems = [
  { text: 'This is a sale text' },
  { dot: true },
  { text: 'Save upto $100 on new Madera Collection' },
  { text: 'Free white-glove delivery over $1000' },
  { dot: true },
  { text: 'Same Build. Friendlier Prices.' },
  { dot: true },
  { text: '14 Days From First Cut To Your Front Door' },
];

const galleryCards = [
  { img: imgGalleryTables, label: 'Tables', w: 'w-[320px] lg:w-[563px]', aspect: 'aspect-[563/394]' },
  { img: imgGalleryBuffets, label: 'Buffets', w: 'w-[260px] lg:w-[446px]', aspect: 'aspect-[446/576]' },
  { img: imgGalleryBenches, label: 'Benches', w: 'w-[320px] lg:w-[563px]', aspect: 'aspect-[563/394]' },
  { img: imgGalleryChairs, label: 'Lounge & Dining Chairs', w: 'w-[320px] lg:w-[563px]', aspect: 'aspect-[563/394]' },
];
---
<Base title="Dining Collections | Urban Woodcraft" description="Solid hardwood dining tables, chairs, benches, and buffets crafted from reclaimed teak.">
  <main class="bg-cream flex flex-col items-stretch relative w-full overflow-x-hidden">

    <!-- ───────────────────────────── Utility Bar ───────────────────────────── -->
    <div class="bg-dark flex flex-wrap items-center justify-between px-5 md:px-12 lg:px-[80px] py-3 w-full text-body-3 text-white">
      <div class="flex gap-6 items-center">
        <p>Free shipping across US &amp; Canada</p>
        <span class="bg-white/30 size-[4px] rounded-full shrink-0" aria-hidden></span>
        <p>Free returns within 7 days</p>
        <span class="bg-white/30 size-[4px] rounded-full shrink-0" aria-hidden></span>
        <p>Book a private viewing · 1-855-738-1378</p>
      </div>
      <div class="hidden md:flex gap-4 text-body-3 text-white">
        <p>EN</p>
        <p>USD</p>
      </div>
    </div>

    <!-- ───────────────────────────── Editorial Hero (Nav + Heading) ───────────────────────────── -->
    <section class="reveal flex flex-col items-stretch overflow-clip w-full bg-[#f9f6f1]">
      <!-- Top Nav -->
      <div class="flex flex-wrap gap-4 lg:gap-0 h-auto lg:h-[120px] items-center justify-between px-5 md:px-12 lg:px-[120px] py-5 lg:py-0 w-full">
        <a href="/uwc-website/" class="leading-none text-[44px] sm:text-[64px] lg:text-[96px] text-dark tracking-tight lg:tracking-[-3.84px] whitespace-nowrap">
          <span class="font-light lg:tracking-[-0.64px]">urban</span><span class="font-bold lg:tracking-[-0.64px]">woodcraft</span>
        </a>
        <nav class="hidden md:flex gap-4 lg:gap-[24px] items-center text-button text-dark order-3 lg:order-none w-full lg:w-auto justify-center lg:justify-start">
          <a href="#" class="link-hover">Menu</a>
          <a href="#" class="link-hover">Search</a>
          <a href="#" class="link-hover">account</a>
          <a href="#" class="link-hover">Cart (0)</a>
        </nav>
        <a href="#" class="bg-dark flex items-center px-[18px] py-[12px] rounded-full transition-transform duration-200 hover:scale-105">
          <p class="text-button text-white">SALE!</p>
        </a>
      </div>

      <!-- Category Nav Strip -->
      <nav class="border-dark/10 border-b border-t text-button w-full">
        <div class="flex gap-6 lg:gap-0 h-[56px] lg:h-[72px] items-center lg:justify-between px-5 md:px-12 lg:px-[120px] overflow-x-auto whitespace-nowrap [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          <a href="#" class="text-dark font-bold">dining</a>
          <a href="#" class="link-hover text-secondary">living</a>
          <a href="#" class="link-hover text-secondary">bedroom</a>
          <a href="#" class="link-hover text-secondary">STORAGE</a>
          <a href="#" class="link-hover text-secondary">BARN DOORS</a>
          <a href="#" class="link-hover text-secondary">vanities</a>
          <a href="#" class="link-hover text-secondary">occassional</a>
        </div>
      </nav>

      <!-- Giant Display Heading -->
      <div class="flex items-center justify-center overflow-clip py-10 lg:py-[64px] w-full">
        <h1 class="text-center text-dark font-medium leading-[1] tracking-[-0.04em] text-[72px] md:text-[120px] lg:text-[168px] whitespace-nowrap">DINING COLLECTIONS</h1>
      </div>
    </section>

    <!-- ───────────────────────────── Image over Text ───────────────────────────── -->
    <section class="reveal flex flex-col w-full">
      <!-- Full-width hero image -->
      <div class="aspect-[1512/630] w-full overflow-hidden relative">
        <img alt="Dining collection hero" class="parallax-img" src={imgDiningHero} loading="lazy" />
      </div>
      <!-- Two-column text band -->
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-[168px] items-start px-5 md:px-12 lg:px-[80px] py-10 lg:py-[48px] w-full">
        <header class="flex flex-1 flex-col gap-[10px] items-start min-w-0">
          <div class="flex gap-[8px] items-center">
            <div class="bg-orange size-[6px]"></div>
            <p class="text-eyebrow text-secondary">the collection</p>
          </div>
          <h2 class="text-h2 text-dark">Solid hardwood, reclaimed teak</h2>
        </header>
        <div class="flex flex-1 flex-col gap-6 lg:gap-[24px] items-start min-w-0 text-dark">
          <p class="text-body-2">The kind of furniture that gets better with every passing year. Each piece starts as reclaimed teak with its own story.</p>
          <p class="text-body-2 max-w-[486px]">We shape it, build around it, and finish it by hand. Designed to feel like it has always belonged, and built to prove it. From dining tables to benches, every piece in this collection carries character you can see and strength you can feel.</p>
        </div>
      </div>
    </section>

    <!-- ───────────────────────────── Image Gallery (horizontal scroll) ───────────────────────────── -->
    <section class="reveal w-full py-10 lg:py-[64px]">
      <div class="carousel px-5 md:px-12 lg:px-[80px]">
        {galleryCards.map((card) => (
          <a href="#" class={`group relative flex-shrink-0 overflow-hidden ${card.w} ${card.aspect}`}>
            <img alt="" class="card-img size-full object-cover" src={card.img} loading="lazy" />
            <div class="absolute bottom-0 inset-x-0 h-[120px] bg-gradient-to-t from-black/60 to-transparent backdrop-blur-[2px]"></div>
            <p class="absolute bottom-[24px] left-[24px] text-body-2-emph text-white">{card.label}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ───────────────────────────── Marquee ───────────────────────────── -->
    <section class="reveal w-full">
      <div class="marquee py-6 lg:py-10 text-dark">
        <div class="marquee-track">
          {[...marqueeItems, ...marqueeItems].map((item, i) => (
            item.dot
              ? <div class="bg-[#d9d9d9] size-[8px] shrink-0" aria-hidden={i >= marqueeItems.length}></div>
              : <p class="text-h2 whitespace-nowrap" aria-hidden={i >= marqueeItems.length}>{item.text}</p>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────────────────────────── Product Grid ───────────────────────────── -->
    <section class="reveal bg-cream flex flex-col gap-10 lg:gap-[40px] pb-16 lg:pb-[160px] pt-10 lg:pt-[80px] px-5 md:px-12 lg:px-[80px] w-full">
      <!-- Toolbar -->
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-0 lg:items-center lg:justify-between w-full">
        <!-- Grid/Table toggle -->
        <div class="flex gap-[8px] items-center">
          <button type="button" class="bg-dark text-white flex items-center px-[18px] py-[10px] rounded-full">
            <p class="text-button">Grid</p>
          </button>
          <button type="button" class="bg-transparent border border-dark/20 text-dark flex items-center px-[18px] py-[10px] rounded-full">
            <p class="text-button">Table</p>
          </button>
        </div>
        <!-- Type filters -->
        <div class="flex gap-[8px] items-center overflow-x-auto whitespace-nowrap [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          <button type="button" class="bg-transparent border border-dark/20 text-dark flex items-center px-[18px] py-[10px] rounded-full">
            <p class="text-button">Show All</p>
          </button>
          <button type="button" class="bg-dark text-white flex items-center px-[18px] py-[10px] rounded-full">
            <p class="text-button">Tables</p>
          </button>
          <button type="button" class="bg-transparent border border-dark/20 text-dark flex items-center px-[18px] py-[10px] rounded-full">
            <p class="text-button">Buffets</p>
          </button>
          <button type="button" class="bg-transparent border border-dark/20 text-dark flex items-center px-[18px] py-[10px] rounded-full">
            <p class="text-button">Benches</p>
          </button>
          <button type="button" class="bg-transparent border border-dark/20 text-dark flex items-center px-[18px] py-[10px] rounded-full">
            <p class="text-button">Lounges &amp; Chairs</p>
          </button>
        </div>
        <!-- Sort -->
        <div class="flex gap-[8px] items-center">
          <button type="button" class="bg-transparent border border-dark/20 text-dark flex items-center px-[18px] py-[10px] rounded-full">
            <p class="text-button">Popularity</p>
          </button>
        </div>
      </div>

      <!-- 3-column product grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12 lg:gap-x-[24px] lg:gap-y-[64px]">
        {products.map((p) => (
          <a href="#" class="group flex flex-col gap-[20px] relative">
            <div class="aspect-[1/1] h-auto lg:h-[500px] w-full relative overflow-hidden">
              <img alt="" class="card-img size-full object-cover" src={p.img} loading="lazy" />
            </div>
            {p.badge && (
              <div class={`absolute z-10 bg-white flex gap-[8px] items-center left-[14px] top-[17px] ${p.dot ? 'px-[12px] py-[8px]' : 'p-[8px] justify-center'}`}>
                <p class="text-chip text-dark">{p.badge}</p>
                {p.dot && <div class="bg-orange size-[8px]"></div>}
              </div>
            )}
            <button
              type="button"
              aria-label={`Add ${p.title} to collection`}
              onclick="event.preventDefault();event.stopPropagation();"
              class="absolute right-[16px] top-[16px] z-10 mix-blend-difference"
            >
              <img alt="" class="size-[32px]" src={imgHeartPlus} />
            </button>
            <div class="flex flex-col gap-[2px] text-dark">
              <div class="flex gap-[20px] items-start">
                <p class="card-caption text-body-2-emph flex-1 min-w-0">{p.title}</p>
                <p class="text-body-2-emph text-right whitespace-nowrap">{p.price}</p>
                <img alt="" class="size-[22px] shrink-0 mix-blend-difference" src={imgBaggageClaim} />
              </div>
              <p class="text-body-2 opacity-50">{p.desc}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Load More -->
      <div class="flex items-center justify-center pt-6 lg:pt-[32px]">
        <a class="btn-text border-b border-dark" href="#">
          <p class="text-button text-dark">LOAD MORE</p>
        </a>
      </div>
    </section>

    <!-- ───────────────────────────── Sale Section — Our Sale Is On! ───────────────────────────── -->
    <section class="reveal flex flex-col gap-16 lg:gap-[80px] pt-20 lg:pt-[160px] w-full">
      <div class="flex flex-col gap-6 lg:gap-[24px] py-10 lg:py-[40px]">
        <header class="flex flex-col gap-[10px] items-start px-5 md:px-12 lg:px-[80px]">
          <div class="flex gap-[8px] items-center">
            <div class="bg-orange size-[6px]"></div>
            <p class="text-eyebrow text-dark">select prices</p>
          </div>
          <h2 class="text-h2 text-dark">Our Sale Is On!</h2>
        </header>
        <div class="carousel px-5 md:px-12 lg:px-[80px]">
          {saleCards.map((card) => (
            <a href="#" class="group flex flex-col gap-[16px] w-[280px] md:w-[380px] lg:w-[500px]">
              <div class="aspect-[500/548] w-full overflow-hidden relative">
                <img alt="" class="card-img size-full object-cover" src={card.img} loading="lazy" />
                <div class="absolute bg-orange flex items-center justify-center left-[14px] top-[17px] px-[12px] py-[8px]">
                  <p class="text-chip text-white">{card.discount}</p>
                </div>
              </div>
              <div class="flex flex-col gap-[6px]">
                <p class="card-caption text-body-1 text-dark">{card.title}</p>
                <p class="text-body-2 text-secondary">{card.desc}</p>
              </div>
            </a>
          ))}
        </div>
        <!-- Progress bar -->
        <div class="px-5 md:px-12 lg:px-[80px]">
          <div class="flex items-center w-full">
            <div class="bg-dark h-[4px] w-[358px]"></div>
            <div class="bg-black/10 h-[4px] flex-1"></div>
          </div>
        </div>
      </div>
      <!-- Countdown bar -->
      <div
        class="flex flex-col lg:flex-row items-center lg:justify-between gap-6 lg:gap-0 p-10 lg:p-[80px] w-full bg-cover bg-center relative overflow-hidden"
        style={`background-image: url(${imgSaleCountdownBg})`}
      >
        <p class="text-h2 text-white relative">Sale ends in</p>
        <p class="text-h2 text-white tabular-nums relative">09:23:13</p>
        <a class="btn-text border-b border-white relative" href="#">
          <p class="text-button text-white">Access Now</p>
        </a>
      </div>
    </section>

    <!-- ───────────────────────────── Editorial — Shop by Collections ───────────────────────────── -->
    <section class="reveal flex flex-col gap-6 lg:gap-[24px] py-20 lg:py-[120px] w-full">
      <!-- Two-column text band -->
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-[168px] items-start px-5 md:px-12 lg:px-[120px] pb-6 lg:pb-[24px] w-full">
        <header class="flex flex-1 flex-col gap-[10px] items-start min-w-0">
          <div class="flex gap-[8px] items-center">
            <div class="bg-orange size-[6px]"></div>
            <p class="text-eyebrow text-secondary">shop by collections</p>
          </div>
          <h2 class="text-h2 text-dark">Our Range Of Designs</h2>
        </header>
        <div class="flex flex-1 flex-col gap-6 items-start min-w-0 text-dark">
          <p class="text-body-2 max-w-[486px]">Each dining table collection has its own character, built from a distinct material palette and design philosophy. From sleek reclaimed teak to rustic farmhouse styles, find the collection that fits your space.</p>
        </div>
      </div>
      <!-- Collections carousel -->
      <div class="carousel h-[420px] md:h-[600px] lg:h-[680px] px-5 md:px-12 lg:px-[120px]">
        {collections.map((c) => (
          <a href="#" class="group collection-card w-[240px] lg:w-[320px]">
            <img alt="" class="collection-card-img" src={c.img} loading="lazy" />
            <p class="relative text-h3 text-dark">{c.name}</p>
            {c.badge && (
              <div class="absolute bg-white flex items-center justify-center left-[24px] p-[8px] top-[24px]">
                <p class="text-chip text-dark">{c.badge}</p>
              </div>
            )}
          </a>
        ))}
      </div>
      <!-- Display wordmark -->
      <div class="px-5 md:px-12 lg:px-[120px] py-10 lg:py-12 w-full">
        <p class="text-display-wordmark text-dark text-center" style="font-size: clamp(64px, 12vw, 184px);">DINING DESIGNS</p>
      </div>
    </section>

    <!-- ───────────────────────────── Clients Love Us (Testimonials) ───────────────────────────── -->
    <section class="reveal bg-cream flex flex-col gap-10 lg:gap-[48px] px-5 md:px-12 lg:px-[80px] py-16 lg:py-[120px] w-full">
      <!-- Two-column text band -->
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-[168px] items-start w-full">
        <header class="flex flex-1 flex-col gap-[10px] items-start min-w-0">
          <div class="flex gap-[8px] items-center">
            <div class="bg-orange size-[6px]"></div>
            <p class="text-eyebrow text-secondary">testimonials</p>
          </div>
          <h2 class="text-h2 text-dark">Clients Love Us</h2>
        </header>
        <div class="flex flex-1 flex-col gap-6 items-start min-w-0 text-dark">
          <p class="text-body-2 max-w-[486px]">Real reviews from real customers who chose solid wood and never looked back. See what they have to say about craftsmanship, quality, and living with reclaimed teak.</p>
        </div>
      </div>
      <!-- Review cards carousel -->
      <div class="overflow-hidden w-full pb-6 lg:pb-[24px]">
        <div class="testimonial-scroll">
          {[...reviewers, ...reviewers].map((r, i) => (
            <div class={`flex flex-col gap-[24px] bg-[#f9f6f1] p-[32px] w-[300px] md:w-[360px] lg:w-[400px] flex-shrink-0 ${r.offset}`}>
              <div class="flex items-center justify-center size-[60px] rounded-full border-2 border-dark/20">
                <p class="text-body-2-emph text-dark">4.6</p>
              </div>
              <div class="flex flex-col gap-[8px]">
                <p class="text-body-2-emph text-dark">{r.name}</p>
                <p class="text-body-3 text-secondary">Bought 4 weeks ago</p>
              </div>
              <p class="text-body-2 text-dark">{r.quote}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────────────────────────── Bundle Section ───────────────────────────── -->
    <section class="reveal bg-cream flex flex-col gap-12 lg:gap-[64px] px-5 md:px-12 lg:px-[80px] py-16 lg:py-[120px] w-full">
      <!-- Header -->
      <div class="flex flex-col lg:flex-row gap-8 lg:items-end lg:justify-between">
        <div class="flex flex-col gap-6 lg:gap-[24px] items-start max-w-[640px]">
          <div class="flex gap-[8px] items-center">
            <div class="bg-orange size-[6px]"></div>
            <p class="text-eyebrow text-secondary">Bundles</p>
          </div>
          <h2 class="text-h2 text-dark">Get <span class="text-orange">$800-1000</span> with bundles</h2>
          <p class="text-body-2 text-secondary">Bundle your dining table with chairs and a buffet for maximum savings. Complete your dining room in one go.</p>
        </div>
        <a href="#" class="btn-pill btn-pill-dark border-2 px-[32px] py-[14px] rounded-full self-start lg:self-auto">
          <p class="text-button">View DEAL</p>
        </a>
      </div>
      <!-- Bundle product images -->
