            <div class="absolute bg-[rgba(61,43,31,0.05)] inset-0"></div>
            <div class="absolute inset-0 overflow-hidden">
              <img alt="" class="absolute h-[81.27%] left-[-17.36%] max-w-none top-[12.93%] w-[199.31%]" src={imgFrame15} />
            </div>
          </div>
          <p class="relative text-[32px] text-dark whitespace-nowrap">Madera</p>
        </div>
        <!-- collection card 2 - Osaka -->
        <div class="flex h-full items-end p-[24px] relative w-[602px]">
          <div aria-hidden class="absolute inset-0 pointer-events-none">
            <div class="absolute bg-white inset-0"></div>
            <img alt="" class="absolute max-w-none object-contain size-full" src={imgFrame20} />
          </div>
          <p class="relative text-[32px] text-dark whitespace-nowrap">Osaka</p>
        </div>
        <!-- collection card 3 - Hudson -->
        <div class="flex h-full items-end p-[24px] relative w-[320px]">
          <div aria-hidden class="absolute inset-0 pointer-events-none">
            <div class="absolute bg-[rgba(61,43,31,0.05)] inset-0"></div>
            <div class="absolute inset-0 overflow-hidden">
              <img alt="" class="absolute h-[81.27%] left-[0.46%] max-w-none top-[21.6%] w-[199.31%]" src={imgFrame13} />
