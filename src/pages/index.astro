              <div class="flex items-center justify-center py-[6px] relative">
                <p class="text-[22px] text-white w-[259px]">
                  Furniture crafted from solid, reclaimed wood, built to make every room feel more like home.
                </p>
              </div>
              <div class="size-[100px]"></div>
            </div>
          </div>
          <div class="border border-white border-solid flex items-center justify-center p-[8px] rounded-full size-[160px]">
            <p class="font-bold text-[12px] text-white uppercase whitespace-nowrap">discover</p>
