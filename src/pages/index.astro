          </div>
          <p class="relative text-[32px] text-dark whitespace-nowrap">Camden</p>
          <div class="absolute bg-white flex items-center justify-center left-[14.33px] p-[8px] top-[17px]">
            <p class="font-medium text-[16px] text-dark whitespace-nowrap">Popular</p>
          </div>
        </div>
        <!-- collection card 5 - Hudson (duplicate) -->
        <div class="flex h-full items-end p-[24px] relative w-[320px]">
          <div aria-hidden class="absolute inset-0 pointer-events-none">
            <div class="absolute bg-[rgba(61,43,31,0.05)] inset-0"></div>
            <div class="absolute inset-0 overflow-hidden">
              <img alt="" class="absolute h-[81.27%] left-[-17.36%] max-w-none top-[12.93%] w-[199.31%]" src={imgFrame15} />
            </div>
          </div>
          <p class="relative text-[32px] text-dark whitespace-nowrap">Hudson</p>
        </div>
      </div>
    </div>

    <!-- Section — Image over Text -->
    <div class="bg-[#fdfcfb] flex flex-col items-start w-full">
