      </div>
    </div>

    <!-- Most Loved (product grid 3x3) -->
    <div class="bg-[#fdfcfb] flex flex-col gap-[40px] items-center pb-[160px] pt-[24px] px-[80px] w-full">
      <div class="flex items-start w-full">
        <div class="flex flex-1 flex-col gap-[10px] items-start min-w-px">
