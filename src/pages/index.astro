        <p>BARN DOORS</p>
        <p>vanities</p>
        <p>occassional</p>
      </div>
      <!-- Hero content -->
      <div class="flex flex-1 flex-col items-start justify-center min-h-px pb-[80px] pt-[72px] px-[80px] relative w-full">
        <div class="flex flex-1 gap-[32px] items-end relative w-full">
          <div class="flex flex-1 flex-col items-start min-w-px relative">
            <div class="flex gap-[56px] items-end relative w-full">
              <div class="text-[78px] text-white tracking-[-2.34px] whitespace-nowrap leading-none font-medium">
                <p class="leading-[1.1] mb-0">Real wood.</p>
                <p class="leading-[1.1] mb-0">Real craft.</p>
                <p class="leading-[1.1]">Real good.</p>
