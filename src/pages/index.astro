      <div class="flex h-[120px] items-center justify-between px-[120px] relative shrink-0 w-full">
        <p class="leading-none text-[96px] text-white tracking-[-3.84px] whitespace-nowrap font-sans">
          <span class="font-light tracking-[-0.64px]">urban</span><span class="font-bold tracking-[-0.64px]">woodcraft</span>
        </p>
        <div class="flex gap-[24px] items-center font-bold text-[12px] text-white uppercase whitespace-nowrap">
