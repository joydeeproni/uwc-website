                <div class="flex gap-[20px] items-start font-medium text-[18px] text-dark w-full">
                  <p class="flex-1 min-w-px">{p.title}</p>
                  <p class="text-right whitespace-nowrap">{p.price}</p>
                </div>
                <p class="leading-[1.6] text-[16px] text-secondary w-full">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
        <!-- Row 2 -->
        <div class="flex gap-[24px] items-center w-full">
          {[
            { img: imgRectangle12, title: 'Camden Dining Table', price: 'from $1,425', desc: 'Natural Reclaimed Teak' },
            { img: imgRectangle13, title: 'Wadi Sideboard', price: '$1,145', desc: 'Natural Mango Wood', soldOut: true },
            { img: imgRectangle14, title: 'Riviera Bed', price: 'from $2,199', desc: 'Natural Wood', badge: 'New' },
          ].map((p) => (
            <div class="flex flex-1 flex-col gap-[20px] items-start justify-center min-w-px relative">
              <div class={`h-[500px] relative w-full ${p.soldOut ? 'opacity-20' : ''}`}>
                <img alt="" class="absolute inset-0 max-w-none object-cover size-full" src={p.img} />
              </div>
              {p.soldOut && (
                <div class="absolute bg-white flex items-center justify-center left-[14px] opacity-50 p-[8px] top-[17px]">
                  <p class="font-medium text-[16px] text-dark whitespace-nowrap">Sold Out</p>
                </div>
