      <p class="text-[42px] text-dark text-center whitespace-nowrap">This is a sale text</p>
      <div class="bg-[#d9d9d9] size-[87px]"></div>
      <p class="text-[42px] text-dark text-center whitespace-nowrap">Save upto $100 on new Madera Collection</p>
      <p class="text-[42px] text-dark text-center whitespace-nowrap">Free white-glove delivery over $1000</p>
      <div class="bg-[#d9d9d9] size-[87px]"></div>
      <p class="text-[42px] text-dark text-center whitespace-nowrap">Save</p>
      <div class="bg-[#d9d9d9] size-[87px]"></div>
