              {!p.soldOut && (
                <div class="absolute overflow-clip right-[17.67px] size-[32px] top-[21px]">
                  <img alt="" class="absolute inset-[20.83%_16.66%_20.83%_16.67%] block max-w-none" src={imgVector} />
