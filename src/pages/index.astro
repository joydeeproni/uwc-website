        </div>
      </div>
      <div class="flex flex-col gap-[64px] items-start w-full">
        <!-- Row 1 -->
        <div class="flex gap-[24px] items-center w-full">
          {[
            { img: imgRectangle9, title: 'Madera Dining Table', price: 'from $1,870', desc: 'Natural Reclaimed Teak', badge: 'New' },
            { img: imgRectangle10, title: 'Osaka Dining Table', price: 'from $1,990', desc: 'Natural Reclaimed Teak + Grey Concrete' },
            { img: imgRectangle11, title: 'Lugano Bed', price: 'from $1,925', desc: 'Natural Reclaimed Teak', badge: 'Limited Stock', dot: true },
          ].map((p) => (
            <div class="flex flex-1 flex-col gap-[20px] items-start justify-center min-w-px relative">
              <div class="h-[500px] relative w-full">
                <img alt="" class="absolute inset-0 max-w-none object-cover size-full" src={p.img} />
              </div>
              {p.badge && (
                <div class={`absolute bg-white flex gap-[8px] items-center left-[14px] ${p.dot ? 'px-[12px] py-[8px]' : 'p-[8px] justify-center'} top-[17px]`}>
                  <p class="font-medium text-[16px] text-dark whitespace-nowrap">{p.badge}</p>
                  {p.dot && <div class="bg-[#ca670b] size-[8px]"></div>}
                </div>
              )}
              <div class="absolute overflow-clip right-[17.67px] size-[32px] top-[21px]">
