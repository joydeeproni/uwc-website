        <div class="flex gap-[8px] h-full items-end p-[24px] relative w-[320px]">
          <div aria-hidden class="absolute inset-0 pointer-events-none">
            <div class="absolute bg-[rgba(61,43,31,0.05)] inset-0"></div>
            <div class="absolute inset-0 overflow-hidden">
              <img alt="" class="absolute h-[94.87%] left-[5.97%] max-w-none top-[17.01%] w-[232.66%]" src={imgFrame18} />
