        </div>
      </div>
    </div>

    <!-- Shop by Room -->
    <div class="flex flex-col gap-[64px] items-start px-[80px] py-[160px] relative shrink-0 w-full">
      <div class="flex flex-col gap-[10px] items-start w-full">
        <div class="flex gap-[8px] items-center">
          <div class="bg-[#ca670b] size-[6px]"></div>
          <p class="capitalize font-mono text-[12px] text-secondary tracking-[0.24px] whitespace-nowrap">Shop by room</p>
        </div>
        <p class="text-[42px] text-dark whitespace-nowrap">Solid Wood in Every Form</p>
      </div>
      <div class="flex flex-wrap content-start gap-[32px] items-start w-full">
        <div class="flex flex-col gap-[16px] items-start w-[915px]">
          <div class="h-[500px] relative w-full">
            <img alt="" class="absolute inset-0 max-w-none object-cover size-full" src={imgRectangle} />
