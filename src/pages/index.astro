              <p class="leading-[1.6] text-[18px] text-secondary">Get assistance in picking what fits your needs</p>
            </div>
          </div>
          <div class="flex flex-col gap-[16px] items-start justify-center">
            <div class="h-[548px] relative w-[500px]">
              <img alt="" class="absolute inset-0 max-w-none object-cover size-full" src={imgRectangle8} />
            </div>
            <div class="flex flex-col gap-[6px] items-start whitespace-nowrap">
              <p class="text-[22px] text-dark">Grand X Barn Doors</p>
              <p class="leading-[1.6] text-[18px] text-secondary">Now $885 was $1,075</p>
