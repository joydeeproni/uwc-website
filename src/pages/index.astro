                <div class="absolute bg-white flex items-center justify-center left-[14px] p-[8px] top-[17px]">
                  <p class="font-medium text-[16px] text-dark whitespace-nowrap">{p.badge}</p>
                </div>
              )}
              {!p.soldOut && (
                <div class="absolute overflow-clip right-[17.67px] size-[32px] top-[21px]">
                  <img alt="" class="absolute inset-[20.83%_16.66%_20.83%_16.67%] block max-w-none" src={imgVector} />
