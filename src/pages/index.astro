        </div>
        <div class="flex flex-col gap-[16px] items-start w-[405px]">
          <div class="h-[320px] relative w-full overflow-hidden">
            <img alt="" class="absolute h-[216.41%] left-[-16.94%] max-w-none top-[-71.23%] w-[170.99%]" src={imgRectangle4} />
          </div>
          <p class="leading-[1.6] text-[18px] text-dark whitespace-nowrap">Bathroom</p>
        </div>
        <div class="flex flex-col items-start w-[405px]">
          <div class="flex flex-col gap-[16px] items-start w-full">
            <div class="h-[320px] relative w-full overflow-hidden">
              <img alt="" class="absolute h-[126.56%] left-0 max-w-none top-[-0.1%] w-full" src={imgRectangle5} />
            </div>
            <p class="leading-[1.6] text-[18px] text-dark whitespace-nowrap">Barn Doors</p>
          </div>
        </div>
        <div class="flex flex-1 items-center min-w-px relative">
          <div class="border border-dark border-solid flex items-center justify-center p-[8px] rounded-full size-[160px]">
