<script is:inline>
function openMega(id) {
  document.querySelectorAll('[id^="mega-"]').forEach(el => { if(el.id !== id) el.classList.add('hidden'); });
  document.getElementById(id)?.classList.remove('hidden');
}
function closeMega(id) {
  setTimeout(() => {
    const el = document.getElementById(id);
    if (el && !el.matches(':hover')) el.classList.add('hidden');
  }, 300);
}
function switchBundle(idx) {
  document.querySelectorAll('.bundle-row').forEach((row, i) => {
    const isActive = i === idx;
    row.classList.toggle('is-active', isActive);
    row.classList.toggle('border-dark', isActive);
    row.classList.toggle('border-black/10', !isActive);
    row.querySelector('.bundle-title').classList.toggle('text-dark', isActive);
    row.querySelector('.bundle-title').classList.toggle('text-secondary', !isActive);
    const sub = row.querySelector('.bundle-sub');
    const btn = row.querySelector('.bundle-btn');
    if (sub) sub.classList.toggle('hidden', !isActive);
    if (btn) btn.classList.toggle('hidden', !isActive);
  });
  document.querySelectorAll('.bundle-panel').forEach((panel, i) => {
    if (i === idx) {
      panel.classList.remove('hidden');
      panel.style.opacity = '0';
      panel.style.transform = 'translateY(12px)';
      requestAnimationFrame(() => {
        panel.style.transition = 'opacity 400ms ease, transform 400ms ease';
        panel.style.opacity = '1';
        panel.style.transform = 'translateY(0)';
      });
    } else {
      panel.classList.add('hidden');
      panel.style.transition = '';
    }
  });
}

// Founder's Home parallax — text scrolls faster, image scrolls slower
(function() {
  const section = document.querySelector('[data-founders-home]');
  if (!section || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const text = section.querySelector('[data-founders-text]');
  const img = section.querySelector('[data-founders-img]');
  function onScroll() {
    const rect = section.getBoundingClientRect();
    const vh = window.innerHeight;
    if (rect.bottom < 0 || rect.top > vh) return;
    const progress = (vh - rect.top) / (vh + rect.height);
    const offset = (progress - 0.5) * 80;
    text.style.transform = 'translateY(' + (offset * 0.6) + 'px)';
    img.style.transform = 'translateX(-50%) translateY(' + (-offset * 0.3) + 'px)';
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
