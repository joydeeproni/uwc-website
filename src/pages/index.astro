          <p class="leading-[1.6] text-[18px] text-dark whitespace-nowrap">Dining</p>
        </div>
        <div class="flex flex-col gap-[16px] items-start w-[405px]">
          <div class="h-[320px] relative w-full">
            <img alt="" class="absolute inset-0 max-w-none object-cover size-full" src={imgRectangle1} />
