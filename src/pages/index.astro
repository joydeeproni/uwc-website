---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const A = '/assets';
// SVGs
const imgEllipse2 = `${A}/imgEllipse2.svg`;
// PNGs
const imgImage10 = `${A}/imgImage10.png`;
const imgRectangle = `${A}/imgRectangle.png`;
const imgRectangle1 = `${A}/imgRectangle1.png`;
const imgRectangle2 = `${A}/imgRectangle2.png`;
const imgRectangle3 = `${A}/imgRectangle3.png`;
const imgRectangle4 = `${A}/imgRectangle4.png`;
const imgRectangle5 = `${A}/imgRectangle5.png`;
const imgFrame15 = `${A}/imgFrame15.png`;
const imgFrame20 = `${A}/imgFrame20.png`;
const imgFrame13 = `${A}/imgFrame13.png`;
const imgFrame18 = `${A}/imgFrame18.png`;
const imgImageBand = `${A}/imgImageBand.png`;
const imgRectangle6 = `${A}/imgRectangle6.png`;
const imgRectangle7 = `${A}/imgRectangle7.png`;
const imgRectangle8 = `${A}/imgRectangle8.png`;
const imgRectangle9 = `${A}/imgRectangle9.png`;
const imgRectangle10 = `${A}/imgRectangle10.png`;
const imgRectangle11 = `${A}/imgRectangle11.png`;
const imgRectangle12 = `${A}/imgRectangle12.png`;
const imgRectangle13 = `${A}/imgRectangle13.png`;
const imgRectangle14 = `${A}/imgRectangle14.png`;
const imgRectangle15 = `${A}/imgRectangle15.png`;
const imgRectangle16 = `${A}/imgRectangle16.png`;
const imgRectangle17 = `${A}/imgRectangle17.png`;
const imgImage1 = `${A}/imgImage1.png`;
const imgImage2 = `${A}/imgImage2.png`;
const imgImage3 = `${A}/imgImage3.png`;
const imgRectangle18 = `${A}/imgRectangle18.png`;
const imgRectangle19 = `${A}/imgRectangle19.png`;
const imgRectangle20 = `${A}/imgRectangle20.png`;
const imgCleanShot = `${A}/imgCleanShot20260529At1042102X1.png`;
const imgRectangle29 = `${A}/imgRectangle29.png`;
const imgRectangle30 = `${A}/imgRectangle30.png`;
const imgRectangle31 = `${A}/imgRectangle31.png`;
const imgRectangle21 = `${A}/imgRectangle21.png`;
const imgRectangle22 = `${A}/imgRectangle22.png`;
const imgRectangle23 = `${A}/imgRectangle23.png`;
const imgRectangle24 = `${A}/imgRectangle24.png`;
const imgRectangle27 = `${A}/imgRectangle27.png`;
const imgRectangle28 = `${A}/imgRectangle28.png`;
const imgImage12 = `${A}/imgImage12.png`;
const imgImage13 = `${A}/imgImage13.png`;
const imgFrame63 = `${A}/imgFrame63.png`;

const mostLoved = [
  { img: imgRectangle9,  title: 'Madera Dining Table',  price: 'from $1,870', desc: 'Natural Reclaimed Teak', badge: 'New' },
  { img: imgRectangle10, title: 'Osaka Dining Table',   price: 'from $1,990', desc: 'Natural Reclaimed Teak + Grey Concrete' },
  { img: imgRectangle11, title: 'Lugano Bed',           price: 'from $1,925', desc: 'Natural Reclaimed Teak', badge: 'Limited Stock', dot: true },
  { img: imgRectangle12, title: 'Camden Dining Table',  price: 'from $1,425', desc: 'Natural Reclaimed Teak' },
  { img: imgRectangle13, title: 'Wadi Sideboard',       price: '$1,145',      desc: 'Natural Mango Wood', soldOut: true },
  { img: imgRectangle14, title: 'Riviera Bed',          price: 'from $2,199', desc: 'Natural Wood', badge: 'New' },
  { img: imgRectangle15, title: 'Osaka TV Stand',       price: '$1,425',      desc: 'Natural Reclaimed Teak + Grey Concrete', badge: 'Limited Stock', dot: true },
  { img: imgRectangle16, title: 'Villa Coffee Table',   price: 'from $1,450', desc: 'Natural Reclaimed Teak' },
  { img: imgRectangle17, title: 'Vamo Bathroom Vanity', price: '$2,035',      desc: 'Rustic Grey Finish', soldOut: true },
];

const collections = [
  { name: 'Madera',  img: imgFrame15 },
  { name: 'Osaka',   img: imgFrame20 },
  { name: 'Hudson',  img: imgFrame13 },
  { name: 'Camden',  img: imgFrame18, badge: 'Popular' },
  { name: 'Lugano',  img: imgFrame15 },
  { name: 'Atelier', img: imgFrame20 },
  { name: 'Wadi',    img: imgFrame13 },
  { name: 'Riviera', img: imgFrame18 },
  { name: 'Villa',   img: imgFrame15 },
  { name: 'Vamo',    img: imgFrame20 },
];

const newInCards = [
  { img: imgRectangle6,  title: 'Save upto $1000 on Atelier Dining Tables', sub: 'One of the last from this run.' },
  { img: imgRectangle7,  title: 'Discover Personal Shopping',               sub: 'Get assistance in picking what fits your needs' },
  { img: imgRectangle8,  title: 'Grand X Barn Doors',                        sub: 'Now $885 was $1,075' },
  { img: imgRectangle18, title: 'Madera Sideboard',                          sub: 'Limited finishing run' },
  { img: imgRectangle6,  title: 'Riviera Bed Set',                           sub: 'Bundled with linens' },
  { img: imgRectangle7,  title: 'Hudson Coffee Table',                       sub: 'New Spring collection' },
];

const friendlierPrices = [
  { img: imgRectangle6,  title: 'Save upto $1000 on Atelier Dining Tables', sub: 'One of the last from this run.' },
  { img: imgRectangle8,  title: 'Grand X Barn Doors',                        sub: 'Now $885, was $1,075' },
  { img: imgRectangle18, title: 'Priced to move them home.',                 sub: '$1,180 • previously $2,195' },
  { img: imgRectangle7,  title: 'Camden Console',                            sub: 'Save $400' },
  { img: imgRectangle6,  title: 'Villa Coffee Table',                        sub: 'Was $1,890, now $1,425' },
  { img: imgRectangle8,  title: 'Vamo Vanity',                               sub: 'Reduced for shop closing' },
];

const marqueeItems = [
  { text: 'This is a sale text' },
  { dot: true },
  { text: 'Save upto $100 on new Madera Collection' },
  { text: 'Free white-glove delivery over $1000' },
  { dot: true },
  { text: 'Same Build. Friendlier Prices.' },
  { dot: true },
  { text: '14 Days From First Cut To Your Front Door' },
];
---
<Base>
  <main class="bg-cream border border-[#bebebe] flex flex-col items-stretch relative w-full max-w-[1512px] mx-auto overflow-x-hidden">

    <!-- ───────────────────────────── Editorial — Hero ───────────────────────────── -->
    <section
      class="reveal flex flex-col gap-6 lg:gap-[24px] min-h-[560px] lg:h-[960px] items-stretch overflow-clip relative w-full bg-cover bg-center"
      style={`background-image: linear-gradient(rgba(32,22,14,0.55),rgba(32,22,14,0.55)), url(${imgRectangle3})`}
    >
      <div class="flex flex-wrap gap-4 lg:gap-0 h-auto lg:h-[120px] items-center justify-between px-5 md:px-12 lg:px-[120px] py-5 lg:py-0 w-full">
        <a href="#" class="leading-none text-[44px] sm:text-[64px] lg:text-[96px] text-white tracking-tight lg:tracking-[-3.84px] whitespace-nowrap">
          <span class="font-light lg:tracking-[-0.64px]">urban</span><span class="font-bold lg:tracking-[-0.64px]">woodcraft</span>
        </a>
        <nav class="hidden md:flex gap-4 lg:gap-[24px] items-center text-button text-white order-3 lg:order-none w-full lg:w-auto justify-center lg:justify-start">
          <a href="#" class="link-hover">Menu</a>
          <a href="#" class="link-hover">Search</a>
          <a href="#" class="link-hover">account</a>
          <a href="#" class="link-hover">Cart (0)</a>
        </nav>
        <a href="#" class="bg-white flex items-center px-[18px] py-[12px] rounded-full transition-transform duration-200 hover:scale-105">
          <p class="text-button text-dark">SALE!</p>
        </a>
      </div>
      <nav class="border-brand-border border-b border-t text-button text-white w-full">
        <div class="flex gap-6 lg:gap-0 h-[56px] lg:h-[72px] items-center lg:justify-between px-5 md:px-12 lg:px-[120px] overflow-x-auto whitespace-nowrap [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          <a href="#" class="link-hover">dining</a>
          <a href="#" class="link-hover">living</a>
          <a href="#" class="link-hover">bedroom</a>
          <a href="#" class="link-hover">STORAGE</a>
          <a href="#" class="link-hover">BARN DOORS</a>
          <a href="#" class="link-hover">vanities</a>
          <a href="#" class="link-hover">occassional</a>
        </div>
      </nav>
      <div class="flex flex-1 flex-col gap-6 items-start justify-end pb-10 lg:pb-[80px] pt-8 lg:pt-[72px] px-5 md:px-12 lg:px-[80px] w-full">
        <div class="flex flex-col lg:flex-row gap-6 lg:gap-[32px] items-start lg:items-end w-full">
          <div class="flex flex-col lg:flex-row flex-1 gap-6 lg:gap-[56px] items-start lg:items-end">
            <h1 class="text-h1 text-white">
              <span class="block leading-[1.1]">Real wood.</span>
              <span class="block leading-[1.1]">Real craft.</span>
              <span class="block leading-[1.1]">Real good.</span>
            </h1>
            <p class="text-body-1 text-white max-w-[259px]">
              Furniture crafted from solid, reclaimed wood, built to make every room feel more like home.
            </p>
          </div>
          <a href="#" class="btn-pill btn-pill-light border size-[120px] lg:size-[160px] shrink-0">
            <p class="text-button">discover</p>
          </a>
        </div>
      </div>
    </section>

    <!-- ───────────────────────────── Shop by Room ───────────────────────────── -->
    <section class="reveal flex flex-col gap-10 lg:gap-[64px] px-5 md:px-12 lg:px-[80px] py-20 lg:py-[160px] w-full">
      <header class="flex flex-col gap-[10px] items-start">
        <div class="flex gap-[8px] items-center">
          <div class="bg-orange size-[6px]"></div>
          <p class="text-eyebrow text-secondary">Shop by room</p>
        </div>
        <h2 class="text-h2 text-dark">Solid Wood in Every Form</h2>
      </header>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-[16px] md:gap-[24px] lg:gap-[32px]">
        <a class="group flex flex-col gap-[16px] lg:col-span-7 lg:row-span-2" href="#">
          <div class="aspect-[915/500] lg:aspect-auto lg:h-[500px] w-full overflow-hidden">
            <img alt="" class="card-img size-full object-cover" src={imgRectangle} loading="lazy" />
          </div>
          <p class="card-caption text-body-2 text-dark">Dining</p>
        </a>
        <a class="group flex flex-col gap-[16px] lg:col-span-5" href="#">
          <div class="aspect-[405/320] w-full overflow-hidden">
            <img alt="" class="card-img size-full object-cover" src={imgRectangle1} loading="lazy" />
          </div>
          <p class="card-caption text-body-2 text-dark">Storage</p>
        </a>
        <a class="group flex flex-col gap-[16px] lg:col-span-5" href="#">
          <div class="aspect-[405/320] w-full overflow-hidden">
            <img alt="" class="card-img size-full object-cover object-center" src={imgRectangle2} loading="lazy" />
          </div>
          <p class="card-caption text-body-2 text-dark">Living</p>
        </a>
        <a class="group flex flex-col gap-[16px] lg:col-span-7 lg:row-span-2" href="#">
          <div class="aspect-[843/500] lg:aspect-auto lg:h-[500px] w-full overflow-hidden">
            <img alt="" class="card-img size-full object-cover" src={imgRectangle3} loading="lazy" />
          </div>
          <p class="card-caption text-body-2 text-dark">Bedroom</p>
        </a>
        <a class="group flex flex-col gap-[16px] lg:col-span-3" href="#">
          <div class="aspect-[405/320] w-full overflow-hidden">
            <img alt="" class="card-img size-full object-cover" src={imgRectangle4} loading="lazy" />
          </div>
          <p class="card-caption text-body-2 text-dark">Bathroom</p>
        </a>
        <a class="group flex flex-col gap-[16px] lg:col-span-2" href="#">
          <div class="aspect-[405/320] w-full overflow-hidden">
            <img alt="" class="card-img size-full object-cover" src={imgRectangle5} loading="lazy" />
          </div>
          <p class="card-caption text-body-2 text-dark">Barn Doors</p>
        </a>
        <div class="flex items-center justify-center md:col-span-2 lg:col-span-2">
          <a href="#" class="btn-pill btn-pill-dark border size-[120px] lg:size-[160px]">
            <p class="text-button">discover</p>
          </a>
        </div>
      </div>
    </section>

    <!-- ───────────────────────────── Marquee (auto-scroll) ───────────────────────────── -->
    <section class="reveal w-full">
      <div class="marquee py-6 lg:py-10 text-dark">
        <div class="marquee-track">
          {[...marqueeItems, ...marqueeItems].map((item, i) => (
            item.dot
              ? <div class="bg-[#d9d9d9] size-[40px] lg:size-[87px] shrink-0" aria-hidden={i >= marqueeItems.length}></div>
              : <p class="text-h2 whitespace-nowrap" aria-hidden={i >= marqueeItems.length}>{item.text}</p>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────────────────────────── Shop by Collections (carousel + hover expand) ───────────────────────────── -->
    <section class="reveal flex flex-col gap-6 lg:gap-[24px] py-20 lg:py-[120px] w-full">
      <header class="flex flex-col gap-[10px] items-start px-5 md:px-12 lg:px-[120px] w-full">
        <div class="flex gap-[8px] items-center">
          <div class="bg-orange size-[6px]"></div>
          <p class="text-eyebrow text-secondary">shop by collections</p>
        </div>
        <h2 class="text-h2 text-dark">Design For Everyone</h2>
      </header>
      <div class="carousel h-[420px] md:h-[600px] lg:h-[680px] px-5 md:px-12 lg:px-[120px]">
        {collections.map((c) => (
          <a href="#" class="group collection-card w-[240px] lg:w-[320px]">
            <img alt="" class="collection-card-img" src={c.img} loading="lazy" />
            <p class="relative text-h3 text-dark">{c.name}</p>
            {c.badge && (
              <div class="absolute bg-white flex items-center justify-center left-[24px] p-[8px] top-[24px]">
                <p class="text-chip text-dark">{c.badge}</p>
              </div>
            )}
          </a>
        ))}
      </div>
    </section>

    <!-- ───────────────────────────── New In (image band + carousel) ───────────────────────────── -->
    <section class="reveal bg-cream flex flex-col w-full">
      <div class="h-[280px] md:h-[440px] lg:h-[630px] relative w-full overflow-hidden">
        <img alt="" class="absolute h-[359.8%] left-0 max-w-none top-[-165.69%] w-full object-cover" src={imgImageBand} loading="lazy" />
      </div>
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-[168px] items-start px-5 md:px-12 lg:px-[80px] py-10 lg:py-[48px] w-full">
        <header class="flex flex-1 flex-col gap-[10px] items-start min-w-0">
          <div class="flex gap-[8px] items-center">
            <div class="bg-orange size-[6px]"></div>
            <p class="text-eyebrow text-secondary">New In</p>
          </div>
          <h2 class="text-h2 text-dark">Pieces Worth Making Room For.</h2>
        </header>
        <div class="flex flex-1 flex-col gap-6 lg:gap-[24px] items-start min-w-0 text-dark">
          <p class="text-body-2">The kind of furniture that gets better with every passing year.</p>
          <p class="text-body-2 max-w-[486px]">Each one starts as reclaimed teak with its own story. We shape it, build around it, and finish it by hand. Designed to feel like it's always belonged, and built to prove it.</p>
        </div>
      </div>
      <!-- New In carousel -->
      <div class="carousel pb-16 lg:pb-[160px] pt-2 lg:pt-0 px-5 md:px-12 lg:px-[80px]">
        {newInCards.map((card) => (
          <a href="#" class="group flex flex-col gap-[16px] w-[280px] md:w-[380px] lg:w-[500px]">
            <div class="aspect-[500/548] w-full overflow-hidden">
              <img alt="" class="card-img size-full object-cover" src={card.img} loading="lazy" />
            </div>
            <div class="flex flex-col gap-[6px]">
              <p class="card-caption text-body-1 text-dark">{card.title}</p>
              <p class="text-body-2 text-secondary">{card.sub}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ───────────────────────────── Most Loved (product grid with + icon) ───────────────────────────── -->
    <section class="reveal bg-cream flex flex-col gap-10 lg:gap-[40px] pb-16 lg:pb-[160px] pt-6 lg:pt-[24px] px-5 md:px-12 lg:px-[80px] w-full">
      <header class="flex flex-col gap-[10px] items-start">
        <div class="flex gap-[8px] items-center">
          <div class="bg-orange size-[6px]"></div>
          <p class="text-eyebrow text-secondary">Most Loved</p>
        </div>
        <h2 class="text-h2 text-dark">Consumer Favourites, Season After Season</h2>
      </header>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12 lg:gap-x-[24px] lg:gap-y-[64px]">
        {mostLoved.map((p) => (
          <a href="#" class="group flex flex-col gap-[20px] relative">
            <div class={`aspect-[440/500] w-full relative overflow-hidden ${p.soldOut ? 'opacity-20' : ''}`}>
              <img alt="" class="card-img size-full object-cover" src={p.img} loading="lazy" />
            </div>
            {p.badge && (
              <div class={`absolute z-10 bg-white flex gap-[8px] items-center left-[14px] top-[17px] ${p.dot ? 'px-[12px] py-[8px]' : 'p-[8px] justify-center'}`}>
                <p class="text-chip text-dark">{p.badge}</p>
                {p.dot && <div class="bg-orange size-[8px]"></div>}
              </div>
            )}
            {p.soldOut && (
              <div class="absolute z-10 bg-white flex items-center justify-center left-[14px] opacity-50 p-[8px] top-[17px]">
                <p class="text-chip text-dark">Sold Out</p>
              </div>
            )}
            {!p.soldOut && (
              <button
                type="button"
                aria-label={`Add ${p.title} to collection`}
                onclick="event.preventDefault();event.stopPropagation();"
                class="btn-fav absolute right-[10px] top-[14px] z-10 group/fav"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-[18px] text-dark">
                  <path d="M12 5v14M5 12h14" stroke-linecap="round" />
                </svg>
              </button>
            )}
            <div class="flex flex-col gap-[2px] text-dark">
              <div class="flex gap-[20px] items-start">
                <p class="card-caption text-body-2-emph flex-1 min-w-0">{p.title}</p>
                <p class="text-body-2-emph text-right whitespace-nowrap">{p.price}</p>
              </div>
              <p class="text-body-2 opacity-50">{p.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ───────────────────────────── Editorial — Texture ───────────────────────────── -->
    <section class="reveal bg-cream flex flex-col overflow-clip w-full">
      <div class="flex h-auto lg:h-[120px] items-center justify-between px-5 md:px-12 lg:px-[80px] py-6 lg:py-0 w-full">
        <div class="hidden lg:block h-[15px] w-[324px]"></div>
        <p class="leading-none text-[#3d2b1f] text-[40px] md:text-[60px] lg:text-[96px] font-medium">Madera</p>
      </div>
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-[120px] items-start lg:h-[520px] px-5 md:px-12 lg:px-[80px] w-full">
        <div class="flex flex-col gap-[12px] items-start lg:w-[378px] lg:h-full">
          <div class="flex gap-[8px] items-center">
            <div class="bg-orange size-[6px]"></div>
            <p class="text-eyebrow text-secondary">collections</p>
          </div>
          <h2 class="text-h2 text-[#3d2b1f]">Each Collection, Its Own World</h2>
          <p class="text-body-2 text-secondary">Each collection is its own design world, built around a distinct material and a clear aesthetic. We don't build collections for the sake of range. We build them when we have something worth saying. Each one is considered from the first sketch to the final finish, and built to feel like it was always meant to be in your home.</p>
        </div>
        <div class="grid grid-cols-2 gap-0 flex-1 w-full lg:h-full aspect-[2/1] lg:aspect-auto">
          <div class="relative overflow-hidden">
            <img alt="" class="absolute h-[190.96%] left-[-11.71%] max-w-none top-[-54.97%] w-[239.28%]" src={imgImage1} loading="lazy" />
          </div>
          <div class="relative overflow-hidden">
            <img alt="" class="absolute inset-0 size-full object-cover" src={imgImage2} loading="lazy" />
            <img alt="" class="absolute h-[191.51%] left-[-111.09%] max-w-none top-[-55.19%] w-[239.96%]" src={imgImage3} loading="lazy" />
          </div>
        </div>
      </div>
      <div class="px-5 md:px-12 lg:px-[120px] py-10 lg:py-12 w-full">
        <p class="text-display-wordmark text-[#3d2b1f] text-center">COLLECTIONS</p>
      </div>
    </section>

    <!-- ───────────────────────────── Same Build. Friendlier Prices. (carousel) ───────────────────────────── -->
    <section class="reveal flex flex-col gap-16 lg:gap-[80px] pt-20 lg:pt-[160px] w-full">
      <div class="flex flex-col gap-6 lg:gap-[24px] py-10 lg:py-[40px]">
        <header class="flex flex-col gap-[10px] items-start px-5 md:px-12 lg:px-[80px]">
          <div class="flex gap-[8px] items-center">
            <div class="bg-orange size-[6px]"></div>
            <p class="text-eyebrow text-dark">select prices</p>
          </div>
          <h2 class="text-h2 text-dark">Same Build. Friendlier Prices.</h2>
        </header>
        <div class="carousel px-5 md:px-12 lg:px-[80px]">
          {friendlierPrices.map((card) => (
            <a href="#" class="group flex flex-col gap-[16px] w-[280px] md:w-[380px] lg:w-[500px]">
              <div class="aspect-[500/548] w-full overflow-hidden">
                <img alt="" class="card-img size-full object-cover" src={card.img} loading="lazy" />
              </div>
              <div class="flex flex-col gap-[6px]">
                <p class="card-caption text-body-1 text-dark">{card.title}</p>
                <p class="text-body-2 text-secondary">{card.sub}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
      <div class="bg-orange flex flex-col lg:flex-row items-center lg:justify-between gap-6 lg:gap-0 p-10 lg:p-[80px] w-full">
        <p class="text-h2 text-white">Sale ends in</p>
        <p class="text-h2 text-white tabular-nums">09:23:13</p>
        <a class="btn-text border-b border-white" href="#">
          <p class="text-button text-white">Access Now</p>
        </a>
      </div>
    </section>

